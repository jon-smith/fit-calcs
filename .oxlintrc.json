{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "oxc",
    "react",
    "import",
    "jsx-a11y",
    "promise"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error",
    "pedantic": "error"
  },
  "env": {
    "browser": true,
    "es2026": true
  },
  "settings": {
    "react": {
      "version": "19.2.7"
    }
  },
  "rules": {
    "import/no-unassigned-import": "off",
    "react/react-in-jsx-scope": "off"
  },
  "options": {
    "typeAware": true,
    "denyWarnings": true,
    "maxWarnings": 0,
    "reportUnusedDisableDirectives": "error"
  },
  "overrides": [
    {
      "files": ["vite.config.ts"],
      "env": {
        "browser": false,
        "node": true,
        "es2026": true
      }
    }
  ]
}
